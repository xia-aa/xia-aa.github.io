{
	"compatibility_date": "2026-06-02",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"name": "root",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"routes": [
    { "pattern": "xiaa.cc.cd/*", "zone_name": "xiaa.cc.cd" }
  ],
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "812c4873bca24f94afa837b8e2be3553"
    }
  ]
}